# ========================
# 操作系统 & IDE 产生的缓存文件
# ========================
.DS_Store
Thumbs.db
.vscode/
.idea/

# ========================
# Python 缓存及虚拟环境
# ========================
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.env/

# ========================
# 日志文件
# ========================
log/
logs/
*.log

# ========================
# 大型数据文件 & AI模型权重
# ========================
*.csv
*.npy
*.onnx
*.pt
*.pth

# ========================
# 特定数据缓存和生成目录（保留目录结构）
# ========================
生成数据集/*
!生成数据集/.gitkeep
完成模型/*
!完成模型/.gitkeep
实飞数据收集_树莓派内使用/*
!实飞数据收集_树莓派内使用/.gitkeep
实飞数据_树莓派内收集/*
!实飞数据_树莓派内收集/.gitkeep
